{{ 'virasat-homepage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'virasat-homepage.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="vt-hero color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  id="Hero-{{ section.id }}"
>
  <div class="vt-hero__grid">
    {%- comment -%} LEFT — Content {%- endcomment -%}
    <div class="vt-hero__content">
      {%- if section.settings.label != blank -%}
        <p class="vt-hero__label vt-hp-reveal">{{ section.settings.label }}</p>
      {%- endif -%}

      <div class="vt-hero__accent vt-hp-reveal vt-hp-reveal--d1"></div>

      {%- if section.settings.heading != blank -%}
        <h1 class="vt-hero__heading vt-hp-reveal vt-hp-reveal--d1">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="vt-hero__description vt-hp-reveal vt-hp-reveal--d2">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      <div class="vt-hero__actions vt-hp-reveal vt-hp-reveal--d3">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            href="{{ section.settings.button_link_1 }}"
            class="vt-hero__btn vt-hero__btn--primary"
          >
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_label_2 != blank -%}
          <a
            href="{{ section.settings.button_link_2 }}"
            class="vt-hero__btn vt-hero__btn--secondary"
          >
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} RIGHT — Layered Images {%- endcomment -%}
    <div class="vt-hero__images vt-hp-reveal vt-hp-reveal--d2">
      {%- if section.settings.image_1 != blank -%}
        <div class="vt-hero__img-wrap vt-hero__img-wrap--1">
          {{
            section.settings.image_1
            | image_url: width: 900
            | image_tag:
              widths: '360, 540, 720, 900',
              sizes: '(min-width: 990px) 35vw, 70vw',
              loading: 'eager',
              fetchpriority: 'high'
          }}
        </div>
      {%- else -%}
        <div class="vt-hero__img-wrap vt-hero__img-wrap--1" style="background: rgba(198,161,91,0.1); display:flex; align-items:center; justify-content:center;">
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if section.settings.image_2 != blank -%}
        <div class="vt-hero__img-wrap vt-hero__img-wrap--2">
          {{
            section.settings.image_2
            | image_url: width: 600
            | image_tag:
              widths: '300, 450, 600',
              sizes: '(min-width: 990px) 25vw, 45vw',
              loading: 'eager'
          }}
        </div>
      {%- else -%}
        <div class="vt-hero__img-wrap vt-hero__img-wrap--2" style="background: rgba(198,161,91,0.08); display:flex; align-items:center; justify-content:center;">
          {{ 'detailed-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if section.settings.image_3 != blank -%}
        <div class="vt-hero__img-wrap vt-hero__img-wrap--3">
          {{
            section.settings.image_3
            | image_url: width: 400
            | image_tag:
              widths: '200, 300, 400',
              sizes: '(min-width: 990px) 15vw, 30vw',
              loading: 'lazy'
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Virasat Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Heritage Collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Where Heritage Meets Modern Elegance"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover handcrafted Indian fashion that celebrates centuries of royal craftsmanship, reimagined for the modern connoisseur."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Main image (large)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Overlapping image (bottom-left)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Accent image (small, desktop only)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Virasat Hero"
    }
  ]
}
{% endschema %}
